    "credentials.no.subtitle" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Add your university username and password to use Mira connection features."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ajoutez votre nom d’utilisateur et votre mot de passe universitaires pour utiliser les fonctions de connexion de Mira."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mira の接続機能を使用するには、大学のユーザー名とパスワードを追加してください。"
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Adaugă numele de utilizator și parola universitară pentru a folosi funcțiile de conectare Mira."
